{
  "name": "product-filter-sink",
  "config": {
    "connector.class": "com.example.kafka.connect.sink.FileSinkConnector",
    "tasks.max": "1",
    "topics": "shops_data_json",
    "file": "/data/output/filtered-products.txt",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "transforms": "filterById",
    "transforms.filterById.type": "com.example.kafka.connect.transform.ProductFilter",
    "transforms.filterById.allowed.products.file": "/etc/kafka-connect/allowed-products.json"
  }
}
